import pandas as pd
import matplotlib.pyplot as plt

# load dataset
df = pd.read_excel("../data/raw/cmhc_rent_data.xlsx")

# preview data
df.head()

# check data structure
df.info()

# check column names
df.columns

# clean column names
df.columns = df.columns.str.strip().str.lower()

df.columns

# example visualization if columns exist
if "year" in df.columns and "average_rent" in df.columns:
    
    rent_by_year = df.groupby("year")["average_rent"].mean()

    rent_by_year.plot()

    plt.title("Average Rent Trend in Toronto")
    plt.xlabel("Year")
    plt.ylabel("Average Rent")

    plt.show()

# check missing values
df.isnull().sum()
